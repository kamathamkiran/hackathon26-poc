{
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Deal Extraction Schema",
    "description": "Schema for the extracted deal model. Every leaf field is wrapped in the extraction metadata object (value, pageNumber, confidence, sourceText). Extraction is best-effort, so fields may be absent; only their shape and business rules are validated when present.",
    "type": "object",
    "definitions": {
      "extractedField": {
        "type": ["object", "null"],
        "properties": {
          "value": { "type": ["string", "null"] },
          "pageNumber": { "type": ["integer", "null"] },
          "confidence": { "type": ["number", "null"] },
          "sourceText": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "properties": {
      "dealName": {
        "allOf": [
          { "$ref": "#/definitions/extractedField" },
          { "properties": { "value": { "type": ["string", "null"], "maxLength": 40 } } }
        ]
      },
      "currency": { "$ref": "#/definitions/extractedField" },
      "department": { "$ref": "#/definitions/extractedField" },
      "branch": { "$ref": "#/definitions/extractedField" },
      "processingAreaCode": { "$ref": "#/definitions/extractedField" },
      "classification": { "$ref": "#/definitions/extractedField" },
      "agreementDate": { "$ref": "#/definitions/extractedField" },
      "globalDealProposedCommitmentAmount": { "$ref": "#/definitions/extractedField" },
      "expenseCode": { "$ref": "#/definitions/extractedField" },
      "dealAdminAgent": {
        "type": ["object", "null"],
        "properties": {
          "customerExternalId": {
            "allOf": [
              { "$ref": "#/definitions/extractedField" },
              { "properties": { "value": { "type": ["string", "null"], "maxLength": 15 } } }
            ]
          },
          "dealAdminServicingGroup": {
            "type": ["object", "null"],
            "properties": {
              "profileType": { "$ref": "#/definitions/extractedField" }
            }
          }
        }
      },
      "dealBorrower": {
        "type": ["object", "null"],
        "properties": {
          "customerExternalId": {
            "allOf": [
              { "$ref": "#/definitions/extractedField" },
              { "properties": { "value": { "type": ["string", "null"], "maxLength": 15 } } }
            ]
          },
          "borrowerIndicator": { "$ref": "#/definitions/extractedField" }
        }
      },
      "interestPricingOptions": {
        "type": ["array", "null"],
        "items": {
          "type": "object",
          "properties": {
            "pricingOption": { "$ref": "#/definitions/extractedField" }
          }
        }
      },
      "facilityList": {
        "type": ["array", "null"],
        "items": {
          "type": "object",
          "properties": {
            "dealTrackingNumber": {
              "allOf": [
                { "$ref": "#/definitions/extractedField" },
                { "properties": { "value": { "type": ["string", "null"], "maxLength": 12 } } }
              ]
            },
            "facilityName": {
              "allOf": [
                { "$ref": "#/definitions/extractedField" },
                { "properties": { "value": { "type": ["string", "null"], "maxLength": 30 } } }
              ]
            },
            "facilityType": { "$ref": "#/definitions/extractedField" },
            "proposedCommitmentAmount": { "$ref": "#/definitions/extractedField" },
            "closingCommitment": { "$ref": "#/definitions/extractedField" },
            "agreementDate": { "$ref": "#/definitions/extractedField" },
            "effectiveDate": { "$ref": "#/definitions/extractedField" },
            "expiryDate": { "$ref": "#/definitions/extractedField" },
            "finalMaturityDate": { "$ref": "#/definitions/extractedField" },
            "risk": {
              "type": ["object", "null"],
              "properties": {
                "riskTypeCode": { "$ref": "#/definitions/extractedField" }
              }
            },
            "loanPurpose": {
              "type": ["object", "null"],
              "properties": {
                "loanPurposeCode": { "$ref": "#/definitions/extractedField" }
              }
            },
            "facilityInterestPricingList": {
              "type": ["array", "null"],
              "items": {
                "type": "object",
                "properties": {
                  "optionName": { "$ref": "#/definitions/extractedField" },
                  "rateBasis": { "$ref": "#/definitions/extractedField" },
                  "baseRate": { "$ref": "#/definitions/extractedField" },
                  "spread": { "$ref": "#/definitions/extractedField" }
                }
              }
            },
            "facilitySublimit": { "$ref": "#/definitions/extractedField" },
            "facilityRid": { "$ref": "#/definitions/extractedField" },
            "globalNewAmount": { "$ref": "#/definitions/extractedField" }
          }
        }
      }
    }
  }
}
